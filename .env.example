# ── Required ─────────────────────────────────────────────────────────────────
# Your Discord channel webhook URL
# Discord server → Channel settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── Optional ─────────────────────────────────────────────────────────────────
# RSS feed to watch (default: FMHY tracker)
# FEED_URL=https://fmhy-tracker.pages.dev/feed.xml

# How often to poll in minutes (default: 15)
# POLL_INTERVAL_MIN=15

# Path to the seen-items state file (default: rss-seen.json next to the script)
# STATE_FILE=./rss-seen.json
